# Solution 3 backend configuration.
# Copy to .env (which is gitignored) and adjust. On the personal MacBook the
# Azure keys can stay blank: FAKE mode needs no Azure access.

# ---- LLM mode -------------------------------------------------------------
# One of: MOCK | FAKE | CACHED | LIVE. Per-request the X-LLM-Mode header wins;
# this is just the server default when no header is sent.
LLM_MODE=FAKE

# Demo tenant the pipeline scopes every query to (mock auth for now).
DEMO_SPONSOR=helix_therapeutics

# ---- Azure OpenAI (ONLY required for LIVE mode — office laptop) -----------
# Leave blank on the personal MacBook. LiveLLMClient FAILS LOUD if these are
# missing and LIVE is selected — it never silently falls back to mock/fake.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# ---- Database -------------------------------------------------------------
# Host port 55432 avoids clashing with a default local Postgres on 5432.
# Privileged role: seeding, meta access, audit writes.
DATABASE_URL=postgresql+asyncpg://solution3_app:app_pw@localhost:55432/solution3
# Read-only role: Phase 2 executes generated SQL through this connection.
APP_READONLY_DATABASE_URL=postgresql+asyncpg://app_readonly:readonly_pw@localhost:55432/solution3
